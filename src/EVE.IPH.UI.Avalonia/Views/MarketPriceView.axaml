<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVE.IPH.UI.Avalonia.Views.MarketPriceView">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*" RowSpacing="12">
    <StackPanel Spacing="10">
      <TextBlock FontSize="18" FontWeight="SemiBold" Text="Market Prices" />
      <TextBlock Opacity="0.8"
             TextWrapping="Wrap"
             Text="This market slice uses the modern market service and cache over a manual watchlist of item type IDs, and can now rebuild that watchlist from the saved supported legacy update-price categories. The full legacy update/download surface still remains intentionally deferred." />

      <Grid ColumnDefinitions="2*,*,Auto,Auto" ColumnSpacing="12">
        <StackPanel>
          <TextBlock FontWeight="SemiBold" Text="Item Type IDs" />
          <TextBox Text="{Binding TypeIdsText}" Watermark="Comma-separated item type IDs" />
        </StackPanel>

        <StackPanel Grid.Column="1">
          <TextBlock FontWeight="SemiBold" Text="Region ID" />
          <NumericUpDown Minimum="1" Maximum="9999999999999" Value="{Binding RegionId}" />
        </StackPanel>

        <StackPanel Grid.Column="2">
          <TextBlock FontWeight="SemiBold" Text="Source" />
          <ComboBox Width="180" ItemsSource="{Binding SourceOptions}" SelectedItem="{Binding SelectedSource}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom">
          <Button Content="Reload Defaults" Click="ReloadDefaults_Click" IsEnabled="{Binding CanRefresh}" />
          <Button Content="Saved Categories" Click="BuildSavedCategories_Click" IsEnabled="{Binding CanBuildWatchlist}" />
          <Button Content="Load Prices" Click="LoadPrices_Click" IsEnabled="{Binding CanLoadPrices}" />
        </StackPanel>
      </Grid>
    </StackPanel>

    <TextBlock Grid.Row="1" Opacity="0.8" TextWrapping="Wrap" Text="{Binding StatusText}" />

    <ListBox Grid.Row="2" ItemsSource="{Binding Items}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,0,0,8" Padding="12" CornerRadius="10" Background="#101B2B" BorderBrush="#28415F" BorderThickness="1">
            <Grid ColumnDefinitions="3*,Auto,Auto,Auto" ColumnSpacing="16">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                <TextBlock Opacity="0.75" Text="Type ID {Binding TypeId}" />
              </StackPanel>
              <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="Min Sell: {Binding MinSell, StringFormat='{}{0:N2}'}" />
              <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="Max Buy: {Binding MaxBuy, StringFormat='{}{0:N2}'}" />
              <TextBlock Grid.Column="3" HorizontalAlignment="Right" Text="Average: {Binding Average, StringFormat='{}{0:N2}'}" />
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>