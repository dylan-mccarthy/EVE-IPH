<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVE.IPH.UI.Avalonia.Views.CharacterManagementView">
  <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto,*" RowSpacing="12">
    <StackPanel Spacing="10">
      <TextBlock FontSize="20"
                 FontWeight="SemiBold"
                 Text="Character Management" />
      <TextBlock Opacity="0.8"
                 TextWrapping="Wrap"
                 Text="Connect an EVE character through SSO to load the current profile, skill sheet, and standings into the modern app database. A generated All Skills V placeholder is always kept locally so calculations always have a fallback character." />
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="Connect Character"
                Click="ConnectCharacter_Click"
                IsEnabled="{Binding CanConnectCharacter}" />
        <Button Content="Add Corporation"
          Click="ConnectCorporation_Click"
          IsEnabled="{Binding CanConnectCorporation}" />
        <Button Content="Refresh Selected"
                Click="RefreshSelectedCharacter_Click"
                IsEnabled="{Binding CanRefreshSelectedCharacter}" />
        <Button Content="Make Default"
                Click="SetDefaultCharacter_Click"
                IsEnabled="{Binding CanSetDefaultSelectedCharacter}" />
        <Button Content="Remove Character"
                Click="DeleteSelectedCharacter_Click"
                IsEnabled="{Binding CanDeleteSelectedCharacter}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="Refresh Corporation"
          Click="RefreshSelectedCorporation_Click"
          IsEnabled="{Binding CanRefreshSelectedCorporation}" />
        <Button Content="Remove Corporation"
          Click="DeleteSelectedCorporation_Click"
          IsEnabled="{Binding CanDeleteSelectedCorporation}" />
      </StackPanel>
    </StackPanel>

    <TextBlock Grid.Row="1"
               Opacity="0.8"
               TextWrapping="Wrap"
               Text="{Binding StatusText}" />

    <TextBlock Grid.Row="2"
               FontSize="16"
               FontWeight="SemiBold"
               Text="Characters" />

    <ListBox Grid.Row="3"
             ItemsSource="{Binding Characters}"
             SelectedItem="{Binding SelectedCharacter}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,0,0,8"
                  Padding="12"
                  CornerRadius="10"
                  Background="#16263B"
                  BorderBrush="#28415F"
                  BorderThickness="1">
            <Grid ColumnDefinitions="3*,2*,Auto" ColumnSpacing="16">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                <TextBlock Opacity="0.75" Text="{Binding CharacterId}" />
                <TextBlock Opacity="0.75" TextWrapping="Wrap" Text="{Binding TokenStatusText}" />
              </StackPanel>

              <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding CorporationId}" />
                <TextBlock Opacity="0.75" Text="{Binding AllianceId}" />
              </StackPanel>

              <Border Grid.Column="2"
                      Padding="8,4"
                      CornerRadius="999"
                      Background="#294B6D"
                      IsVisible="{Binding IsDefault}">
                <TextBlock Text="Default" />
              </Border>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <TextBlock Grid.Row="4"
               FontSize="16"
               FontWeight="SemiBold"
               Text="Corporations" />

    <ListBox Grid.Row="5"
             ItemsSource="{Binding Corporations}"
             SelectedItem="{Binding SelectedCorporation}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,0,0,8"
                  Padding="12"
                  CornerRadius="10"
                  Background="#16263B"
                  BorderBrush="#28415F"
                  BorderThickness="1">
            <Grid ColumnDefinitions="3*,2*" ColumnSpacing="16">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                <TextBlock Opacity="0.75" Text="{Binding CorporationId}" />
              </StackPanel>

              <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding AccessSummary}" />
                <TextBlock Opacity="0.75" Text="{Binding AuthorizedCharacterName, StringFormat=Authorized by {0}}" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>