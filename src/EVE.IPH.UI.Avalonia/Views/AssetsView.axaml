<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVE.IPH.UI.Avalonia.Views.AssetsView">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*" RowSpacing="12">
    <StackPanel Orientation="Horizontal" Spacing="12">
      <TextBox Width="260"
               Watermark="Search assets or locations"
               Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
      <CheckBox VerticalAlignment="Center"
                Content="Blueprint copies only"
                IsChecked="{Binding OnlyBlueprintCopies}" />
      <ComboBox Width="140"
                ItemsSource="{Binding SortModes}"
                SelectedItem="{Binding SelectedSortMode}" />
    </StackPanel>

    <TextBlock Grid.Row="1"
               Opacity="0.8"
               Text="{Binding StatusText}" />

    <ListBox Grid.Row="2" ItemsSource="{Binding Items}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,0,0,8"
                  Padding="12"
                  CornerRadius="10"
                  Background="#16263B"
                  BorderBrush="#28415F"
                  BorderThickness="1">
            <Grid ColumnDefinitions="3*,2*,Auto" ColumnSpacing="16">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding TypeName}" />
                <TextBlock Opacity="0.75" Text="{Binding TypeGroup}" />
              </StackPanel>

              <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding LocationName}" />
                <TextBlock Opacity="0.75" Text="{Binding FlagText}" />
              </StackPanel>

              <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                <TextBlock HorizontalAlignment="Right" Text="{Binding Quantity}" />
                <TextBlock HorizontalAlignment="Right" Opacity="0.75" Text="{Binding BlueprintKind}" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>