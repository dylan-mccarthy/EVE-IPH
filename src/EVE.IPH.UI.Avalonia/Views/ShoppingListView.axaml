<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVE.IPH.UI.Avalonia.Views.ShoppingListView">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
    <StackPanel Spacing="10">
      <TextBlock FontSize="18" FontWeight="SemiBold" Text="Shopping List" />
      <TextBlock Opacity="0.8"
                 TextWrapping="Wrap"
                 Text="This first shopping-list slice shows the repository-backed persisted list shape that already exists in the modern app-data store. Richer build/buy generation and export workflows remain deferred until a later slice reconstructs more than the current persisted schema preserves." />

      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="Reload" Click="Reload_Click" IsEnabled="{Binding CanRefresh}" />
        <Button Content="Clear List" Click="Clear_Click" IsEnabled="{Binding CanClearItems}" />
      </StackPanel>
    </StackPanel>

    <TextBlock Grid.Row="1" Opacity="0.8" TextWrapping="Wrap" Text="{Binding StatusText}" />

    <ListBox Grid.Row="2" ItemsSource="{Binding Items}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,0,0,8" Padding="12" CornerRadius="10" Background="#101B2B" BorderBrush="#28415F" BorderThickness="1">
            <Grid ColumnDefinitions="3*,Auto,Auto,Auto,Auto" ColumnSpacing="16">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding ItemName}" />
                <TextBlock Opacity="0.75" Text="Type ID {Binding TypeId}" />
              </StackPanel>
              <TextBlock Grid.Column="1" Text="Qty: {Binding Quantity}" />
              <TextBlock Grid.Column="2" Text="Unit: {Binding UnitPrice, StringFormat='{}{0:N2}'}" />
              <TextBlock Grid.Column="3" Text="Total: {Binding TotalPrice, StringFormat='{}{0:N2}'}" />
              <Button Grid.Column="4"
                      Content="Remove"
                      Tag="{Binding TypeId}"
                      Click="RemoveItem_Click" />
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Border Grid.Row="3" Padding="16" CornerRadius="12" Background="#101B2B" BorderBrush="#28415F" BorderThickness="1">
      <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="24">
        <TextBlock Text="Rows: {Binding ItemCount}" />
        <TextBlock Grid.Column="1" Text="Quantity: {Binding TotalQuantity}" />
        <TextBlock Grid.Column="2" Text="Total Cost: {Binding TotalCost, StringFormat='{}{0:N2}'}" />
      </Grid>
    </Border>
  </Grid>
</UserControl>