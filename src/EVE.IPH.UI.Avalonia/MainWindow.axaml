<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:views="using:EVE.IPH.UI.Avalonia.Views"
        mc:Ignorable="d"
        x:Class="EVE.IPH.UI.Avalonia.MainWindow"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        Title="EVE IPH Modern">
  <Grid RowDefinitions="Auto,*" Margin="24">
    <Border Grid.Row="0"
            Padding="20"
            CornerRadius="16"
            Background="#122033"
            BorderBrush="#28415F"
            BorderThickness="1">
      <StackPanel Spacing="8">
        <TextBlock FontSize="28"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />
        <TextBlock Opacity="0.8"
                   Text="{Binding Subtitle}" />
        <StackPanel Orientation="Horizontal" Spacing="12">
          <Button Content="Import Database File..."
            Click="BrowseLegacyDatabaseImport_Click"
            IsEnabled="{Binding CanBrowseLegacyDatabase}" />
          <Button Content="{Binding LegacyImportButtonText}"
            Click="ImportDetectedLegacyDatabase_Click"
                  IsVisible="{Binding CanImportLegacyDatabase}" />
          <Button Content="Restart Now"
            Click="RestartApplication_Click"
            IsVisible="{Binding RestartRequired}" />
          <TextBlock VerticalAlignment="Center"
                     Opacity="0.75"
                     Text="{Binding LegacyImportSourcePath}" />
        </StackPanel>
        <TextBlock Opacity="0.75"
                   TextWrapping="Wrap"
                   Text="{Binding LegacyImportStatus}" />
      </StackPanel>
    </Border>

    <TabControl Grid.Row="1" Margin="0,20,0,0">
      <TabItem Header="Characters">
        <views:CharacterManagementView DataContext="{Binding CharacterManagement}" />
      </TabItem>
      <TabItem Header="Blueprints">
        <views:BlueprintManagementView DataContext="{Binding Blueprints}" />
      </TabItem>
      <TabItem Header="Manufacturing">
        <views:ManufacturingWorkspaceView DataContext="{Binding Manufacturing}" />
      </TabItem>
      <TabItem Header="Market">
        <views:MarketPriceView DataContext="{Binding Market}" />
      </TabItem>
      <TabItem Header="Shopping List">
        <views:ShoppingListView DataContext="{Binding ShoppingList}" />
      </TabItem>
      <TabItem Header="Mining &amp; Reprocessing">
        <views:MiningReprocessingView DataContext="{Binding MiningReprocessing}" />
      </TabItem>
      <TabItem Header="Facilities">
        <views:StructureFacilityManagementView DataContext="{Binding StructureFacilities}" />
      </TabItem>
      <TabItem Header="Assets">
        <views:AssetsView DataContext="{Binding Assets}" />
      </TabItem>
      <TabItem Header="Industry Jobs">
        <views:IndustryJobsView DataContext="{Binding IndustryJobs}" />
      </TabItem>
      <TabItem Header="Research Agents">
        <views:ResearchAgentsView DataContext="{Binding ResearchAgents}" />
      </TabItem>
      <TabItem Header="Settings">
        <ScrollViewer>
          <StackPanel Margin="0,8,0,0" Spacing="16">
            <Border Padding="16"
                    CornerRadius="12"
                    Background="#101B2B"
                    BorderBrush="#28415F"
                    BorderThickness="1">
              <StackPanel Spacing="8">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Application Database" />
                <TextBlock Opacity="0.8" TextWrapping="Wrap" Text="{Binding SettingsStatusText}" />
                <TextBlock FontWeight="SemiBold" Text="Active database path" />
                <SelectableTextBlock Text="{Binding DatabasePath}" />
                <TextBlock FontWeight="SemiBold" Text="Import status" />
                <TextBlock TextWrapping="Wrap" Text="{Binding LegacyImportStatus}" />
                <TextBlock Opacity="0.75" TextWrapping="Wrap" Text="{Binding LegacyImportSourcePath}" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <Button Content="Import Database File..."
                          Click="BrowseLegacyDatabaseImport_Click"
                          IsEnabled="{Binding CanBrowseLegacyDatabase}" />
                  <Button Content="{Binding LegacyImportButtonText}"
                          Click="ImportDetectedLegacyDatabase_Click"
                          IsVisible="{Binding CanImportLegacyDatabase}" />
                  <Button Content="Restart Now"
                          Click="RestartApplication_Click"
                          IsVisible="{Binding RestartRequired}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="12"
                    Background="#101B2B"
                    BorderBrush="#28415F"
                    BorderThickness="1">
              <StackPanel Spacing="8">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Static Data" />
                <TextBlock Opacity="0.8" TextWrapping="Wrap" Text="The app now bootstraps its supported SDE snapshot from the official JSONL archive instead of depending on a legacy database for core lookup tables." />
                <TextBlock FontWeight="SemiBold" Text="Supported SDE build" />
                <SelectableTextBlock Text="{Binding SupportedStaticDataBuild}" />
                <TextBlock FontWeight="SemiBold" Text="Imported SDE build" />
                <SelectableTextBlock Text="{Binding ImportedStaticDataBuildText}" />
                <TextBlock FontWeight="SemiBold" Text="Imported at" />
                <SelectableTextBlock Text="{Binding StaticDataImportedAtText}" />
                <TextBlock FontWeight="SemiBold" Text="Source archive" />
                <SelectableTextBlock Text="{Binding StaticDataSourceUrl}" />
              </StackPanel>
            </Border>

            <Border Padding="16"
                    CornerRadius="12"
                    Background="#101B2B"
                    BorderBrush="#28415F"
                    BorderThickness="1">
              <StackPanel Spacing="8">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Startup and Updates" />
                <TextBlock Opacity="0.8" TextWrapping="Wrap" Text="{Binding OnboardingStatusText}" />
              <CheckBox Content="Check for updates on startup"
                  IsChecked="{Binding CheckForUpdatesOnStart}" />
              <CheckBox Content="Load assets on startup"
                  IsChecked="{Binding LoadAssetsOnStartup}" />
              <CheckBox Content="Load blueprints on startup"
                  IsChecked="{Binding LoadBlueprintsOnStartup}" />
              <CheckBox Content="Load market data on startup"
                  IsChecked="{Binding LoadMarketDataOnStartup}" />
              <CheckBox Content="Load system cost indices on startup"
                  IsChecked="{Binding LoadSystemCostIndicesOnStartup}" />
              <CheckBox Content="Load public structures on startup"
                  IsChecked="{Binding LoadPublicStructuresOnStartup}" />
              <TextBlock Opacity="0.8" TextWrapping="Wrap" Text="{Binding StartupPreferencesStatusText}" />
              <Button HorizontalAlignment="Left"
                Content="Save Startup Preferences"
                Click="SaveStartupPreferences_Click"
                IsEnabled="{Binding CanSaveStartupPreferences}" />
                <Button HorizontalAlignment="Left"
                        Content="Show Onboarding Dialog"
                        Click="ShowFirstRunOnboarding_Click" />
                <TextBlock Opacity="0.8" TextWrapping="Wrap" Text="{Binding UpdateStatusText}" />
                <Button HorizontalAlignment="Left"
                  Content="Check for Updates Now"
                  Click="CheckForUpdates_Click"
                  IsEnabled="{Binding CanCheckForUpdates}" />
                <Button HorizontalAlignment="Left"
                  Content="Restart to Apply Downloaded Update"
                  Click="ApplyPreparedUpdate_Click"
                  IsVisible="{Binding CanApplyPreparedUpdate}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </Grid>
</Window>