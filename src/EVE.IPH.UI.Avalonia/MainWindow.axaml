<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:views="using:EVE.IPH.UI.Avalonia.Views"
        mc:Ignorable="d"
        x:Class="EVE.IPH.UI.Avalonia.MainWindow"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        Title="EVE IPH Modern">
  <Grid RowDefinitions="Auto,*" Margin="24">
    <Border Grid.Row="0"
            Padding="20"
            CornerRadius="16"
            Background="#122033"
            BorderBrush="#28415F"
            BorderThickness="1">
      <StackPanel Spacing="8">
        <TextBlock FontSize="28"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />
        <TextBlock Opacity="0.8"
                   Text="{Binding Subtitle}" />
      </StackPanel>
    </Border>

    <TabControl Grid.Row="1" Margin="0,20,0,0">
      <TabItem Header="Assets">
        <views:AssetsView DataContext="{Binding Assets}" />
      </TabItem>
      <TabItem Header="Industry Jobs">
        <views:IndustryJobsView DataContext="{Binding IndustryJobs}" />
      </TabItem>
      <TabItem Header="Research Agents">
        <views:ResearchAgentsView DataContext="{Binding ResearchAgents}" />
      </TabItem>
    </TabControl>
  </Grid>
</Window>